annotationTrack = "grid",
preAllocateTracks = 1,
big.gap = 20
)
# Limpiar
circos.clear()
set.seed(123)
df <- data.frame(
Protein = sample(paste0("P", 1:10), 20, replace = TRUE),
Function = sample(paste0("F", 1:6), 20, replace = TRUE)
)
# Definir sectores: primero proteínas, luego funciones
df <- df %>% arrange(Function, Protein)
library(dplyr)
# Relación más compleja entre proteínas y funciones
set.seed(123)
df <- data.frame(
Protein = sample(paste0("P", 1:10), 20, replace = TRUE),
Function = sample(paste0("F", 1:6), 20, replace = TRUE)
)
# Definir sectores: primero proteínas, luego funciones
df <- df %>% arrange(Function, Protein)
proteins <- paste0("P", 1:10)
functions <- paste0("F", 1:6)
sectors <- c(proteins, functions)
# Colores
col_proteins <- viridis(length(proteins), option = "D")   # azul verdoso
col_functions <- grDevices::colorRampPalette(colors = c("black", "grey"))(length(functions)) # púrpura-amarillo
grid_colors <- setNames(c(col_proteins, col_functions), sectors)
# Graficar chord diagram
chordDiagram(
x = df,
grid.col = grid_colors,
annotationTrack = "grid",
preAllocateTracks = 1,
big.gap = 20
)
